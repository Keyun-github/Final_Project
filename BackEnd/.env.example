# ============================================
# Server
# ============================================
PORT=3000
NODE_ENV=production
PUBLIC_URL=https://api.kelun.com

# ============================================
# Database (PostgreSQL)
# In Dokploy, use the internal hostname of the postgres service
# In local dev, use localhost or your remote DB
# ============================================
DB_HOST=kelunproject-kelunpostgres-ovam6k
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=
DB_NAME=kelun_db

# ============================================
# Supabase (optional - for file uploads to cloud)
# Leave empty to disable Supabase integration
# ============================================
SUPABASE_URL=
SUPABASE_KEY=

# ============================================
# Midtrans Payment Gateway
# ============================================
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=false
